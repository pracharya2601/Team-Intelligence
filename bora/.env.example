# ──────────────────────────────────────────────────────────────────────────
# Bora — environment template. Copy to .env.local and fill in REAL keys there.
# .env.local is git-ignored; THIS file is committed, so keep it placeholders only.
#
# STACK: Butterbase · Xtrace · Photon(Spectrum) · Nebius · RocketRide · Recall.ai · ElevenLabs
# Claude (chat/notes/Slack) AND Gemini Flash (in-meeting) BOTH go through the
# Butterbase AI gateway — there are NO separate Anthropic/Gemini keys.
# ──────────────────────────────────────────────────────────────────────────

# ── Server / Node scripts + functions (NOT exposed to the browser) ──────────
# bb_sk service key — used by tests, scripts/check.ts, and (when deployed) functions.
BUTTERBASE_API_KEY=            # bb_sk_... (ai:gateway + service)
BUTTERBASE_APP_ID=app_91v2kzy0pe03
BUTTERBASE_API_BASE=https://api.butterbase.ai

# ── Browser (Vite) — MUST be VITE_-prefixed to reach the SPA. NON-secret. ────
# Without these the login URL becomes /auth/undefined/... ("App not found: undefined").
VITE_BUTTERBASE_APP_ID=app_91v2kzy0pe03
VITE_BUTTERBASE_API_BASE=https://api.butterbase.ai

# Model ids on the gateway (allowedModels set on app config).
#   chat/notes/Slack = Claude 4.8 · meetings = Gemini Flash (fast).
BORA_MODEL_CHAT=anthropic/claude-opus-4.8
BORA_MODEL_MEETING=google/gemini-2.5-flash

# Google OAuth + Gmail send + GitHub fetch are configured INSIDE Butterbase
# (manage_oauth / manage_integrations) — those credentials live in Butterbase, not here.

# Nebius — self-hosted cheap always-on trigger model (the only externally-hosted model)
NEBIUS_API_BASE=
NEBIUS_API_KEY=
NEBIUS_TRIGGER_MODEL=

# Recall.ai
RECALL_API_KEY=
RECALL_REGION=us-east-1
RECALL_WORKSPACE_VERIFICATION_SECRET=   # verify webhook/real-time HMAC inline (no svix)

# ElevenLabs (TTS — bytes piped into the bot's Output Media page / Output Audio)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Xtrace (two-tier long-term memory)
XTRACE_API_KEY=               # xtk_...
XTRACE_ORG_ID=

# Photon Spectrum (Slack presence)
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
# (plus the Slack provider vars Spectrum's Slack provider expects)

# RocketRide (fetch/parse context sources → chunks land in Butterbase RAG). No Firecrawl key.
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=

# App
# Public base URL for the bot page + recap links + OAuth redirect.
# Dev SPA runs on http://localhost:5173 (Vite). The in-meeting bot page needs a PUBLIC
# tunnel (e.g. ngrok) — Recall's Output Media blocks localhost.
APP_BASE_URL=http://localhost:5173
